PORT=3001
JWT_SECRET=your-secret-key-change-in-production
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL — Supabase recommended)
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Stripe
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Create a product + recurring price in Stripe Dashboard, then paste the price ID here
STRIPE_SILVER_PRICE_ID=price_your_silver_price_id_here
STRIPE_GOLD_PRICE_ID=price_your_gold_price_id_here
STRIPE_PLATINUM_PRICE_ID=price_your_platinum_price_id_here

# Email Configuration (SMTP)
# For development, you can use Ethereal Email (https://ethereal.email) or Gmail
# For production, use a proper email service like SendGrid, AWS SES, or Mailgun
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="V PATHing Rewards" <noreply@vpathingrewards.com>

# Note: For Gmail, you need to:
# 1. Enable 2-factor authentication
# 2. Generate an App Password (not your regular password)
# 3. Use the App Password in SMTP_PASS
