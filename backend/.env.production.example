# Production Environment Variables
# Copy this file to .env and fill in your production values

# Server Configuration
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# Security
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING-IN-PRODUCTION
# Generate a secure secret: openssl rand -base64 32

# Email Configuration (Production)
# Use a proper email service like SendGrid, AWS SES, or Mailgun
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM="CashBack Rewards" <noreply@yourdomain.com>

# Database (if using external database in production)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Optional: Rate Limiting (adjust for production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin notifications (link checker, system alerts)
ADMIN_EMAIL=vpathingenterprise@gmail.com

# Resend email
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=V PATHing Rewards <noreply@vpathrewards.com>
