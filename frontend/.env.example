# ============================================================================
# VPathRewards — Frontend Env Template (Vite)
# ============================================================================
# Vite env vars are baked into the compiled JS bundle at BUILD time, not
# runtime. Changing a value here (or in Railway) requires a rebuild to take
# effect.
#
# Only variables prefixed with VITE_ are exposed to the browser. Never put
# secrets (API keys, tokens) in this file — anything here ships to the client.
#
# Local dev:
#   1. Copy this file to frontend/.env (which is gitignored).
#   2. Point VITE_API_URL at your local backend (default: http://localhost:3001/api).
#
# Production (Railway):
#   1. Frontend service -> Variables tab -> Raw Editor.
#   2. Paste the line below with the real backend URL.
#   3. Save -> Railway redeploys (which rebuilds the bundle with the new value).
# ============================================================================

# Backend API base URL. Must end with /api — the backend mounts every route
# under /api/* (see backend/src/server.ts).
#
# Local:  http://localhost:3001/api
# Prod:   https://<your-backend>.up.railway.app/api
VITE_API_URL=http://localhost:3001/api
