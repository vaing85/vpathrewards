# ============================================================================
# VPathRewards — Backend Production Env Template (Railway)
# ============================================================================
# This file contains ONLY placeholders. Never commit real secrets.
#
# How to use:
#   1. Copy the contents of this file.
#   2. Railway dashboard -> Backend service -> Variables -> Raw Editor.
#   3. Paste, then replace every <...> with the real value.
#   4. Save. Railway redeploys automatically.
#
# Do NOT set PORT — Railway injects it. Overriding breaks health checks.
# ============================================================================

# ---- Required: server refuses to start or runs insecurely without these
NODE_ENV=production
JWT_SECRET=<run: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))">
FIELD_ENCRYPTION_KEY=<run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
DATABASE_URL=<postgres connection string from Railway Postgres plugin or external provider>
FRONTEND_URL=https://<your-frontend>.up.railway.app

# ---- Stripe (cashback payouts via Stripe Connect; paid subscriptions retired)
STRIPE_SECRET_KEY=sk_live_<your-stripe-secret>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-signing-secret>

# ---- Anthropic (support chat, recommendations, admin insights)
ANTHROPIC_API_KEY=sk-ant-<your-anthropic-key>

# ---- Email (Resend HTTP API). Required for password resets, withdrawal
#      notifications, etc. The sending domain in EMAIL_FROM must be verified
#      in the Resend dashboard (Domains tab). See backend/SETUP_RESEND.md.
#      We use a real mailbox (not `no-reply`) so customer replies work, and
#      route replies through Cloudflare Email Routing on the apex domain to
#      a real inbox.
RESEND_API_KEY=re_<your-resend-api-key>
EMAIL_FROM=VPathRewards <hello@vpathrewards.store>
EMAIL_REPLY_TO=hello@vpathrewards.store

# ---- Cloudflare Turnstile (bot protection on auth forms)
TURNSTILE_SECRET_KEY=<turnstile secret key>

# ---- Operational
ADMIN_EMAIL=vpathingenterprise@gmail.com

# ---- Optional (defaults shown — uncomment only to override)
# JWT_EXPIRES_IN=2h
# ADMIN_JWT_EXPIRES_IN=7d
# LOG_LEVEL=info
# LOG_TO_FILE=false
# MIN_WITHDRAWAL_USD=10
