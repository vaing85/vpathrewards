PORT=3001
JWT_SECRET=your-secret-key-change-in-production
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Minimum withdrawal amount in USD. Optional; defaults to 10 if unset.
# Invalid values fall back to the default with a warning logged at boot.
MIN_WITHDRAWAL_USD=10

# Commission Junction (CJ.com) — optional. When both are set, the cjSync job
# pulls publisher commissions daily and writes them to the cj_commissions
# table. Generate the PAT at https://developers.cj.com under Personal Access
# Tokens. CJ_PUBLISHER_ID is your numeric publisher / CID.
CJ_PERSONAL_ACCESS_TOKEN=
CJ_PUBLISHER_ID=
